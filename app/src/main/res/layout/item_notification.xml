<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_input"
    android:padding="16dp">

    <!-- Chấm tròn báo hiệu chưa đọc -->
    <View
        android:id="@+id/viewUnreadDot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/circle_image_view"
        android:backgroundTint="@color/neon_cyan"
        app:layout_constraintTop_toTopOf="@id/tvNotiTitle"
        app:layout_constraintBottom_toBottomOf="@id/tvNotiTitle"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:id="@+id/tvNotiTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Tiêu đề thông báo"
        android:textColor="@color/text_primary"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/viewUnreadDot"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvNotiContent"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="Nội dung thông báo chi tiết sẽ hiển thị ở đây..."
        android:textColor="@color/text_secondary"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvNotiTitle"
        app:layout_constraintTop_toBottomOf="@id/tvNotiTitle" />

    <TextView
        android:id="@+id/tvNotiTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="2 giờ trước"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tvNotiTitle"
        app:layout_constraintTop_toBottomOf="@id/tvNotiContent" />

</androidx.constraintlayout.widget.ConstraintLayout>