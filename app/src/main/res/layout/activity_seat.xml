<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/img_bg_login_low"
    tools:context=".SeatActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:paddingHorizontal="20dp"
        android:paddingTop="30dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintBottom_toBottomOf="@id/btnBack"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnBack">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CineGo Landmark 81" android:textColor="@color/text_primary" android:textSize="18sp" android:textStyle="bold" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hôm nay • 13:15" android:textColor="@color/neon_cyan" android:textSize="12sp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="120dp"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:layout_width="280dp"
                android:layout_height="50dp"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:src="@drawable/bg_neon_button"
                android:alpha="0.2" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MÀN HÌNH CHÍNH"
                android:textColor="@color/neon_cyan"
                android:textSize="12sp"
                android:letterSpacing="0.2"
                android:layout_gravity="center"
                android:layout_marginTop="-30dp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                android:gravity="center_vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/text_secondary" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lối vào"
                    android:textColor="@color/text_secondary_black"
                    android:textSize="12sp"
                    android:textStyle="italic" />
            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:paddingHorizontal="10dp"
                android:scrollbars="none">

                <GridLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:columnCount="7"
                    android:rowCount="4">

                    <TextView android:id="@+id/seatA1" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:text="A1" android:textColor="@color/text_primary" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatA2" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:text="A2" android:textColor="@color/text_primary" android:gravity="center" android:textSize="11sp"/>
                    <View android:layout_width="20dp" android:layout_height="40dp" />
                    <TextView android:id="@+id/seatA3" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:backgroundTint="#1F2833" android:text="A3" android:textColor="@color/text_primary" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatA4" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:text="A4" android:textColor="@color/text_primary" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatA5" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:text="A5" android:textColor="@color/text_primary" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatA6" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:text="A6" android:textColor="@color/text_primary" android:gravity="center" android:textSize="11sp"/>

                    <TextView android:id="@+id/seatB1" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:backgroundTint="#D4AF37" android:text="B1" android:textColor="@color/bg_main" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatB2" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:backgroundTint="#D4AF37" android:text="B2" android:textColor="@color/bg_main" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <View android:layout_width="20dp" android:layout_height="40dp" />
                    <TextView android:id="@+id/seatB3" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_neon_button" android:text="B3" android:textColor="@color/bg_main" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatB4" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_neon_button" android:text="B4" android:textColor="@color/bg_main" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatB5" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:backgroundTint="#D4AF37" android:text="B5" android:textColor="@color/bg_main" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatB6" android:layout_width="40dp" android:layout_height="40dp" android:layout_margin="4dp" android:background="@drawable/bg_input" android:backgroundTint="#D4AF37" android:text="B6" android:textColor="@color/bg_main" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>

                    <TextView android:id="@+id/seatM1" android:layout_width="88dp" android:layout_height="40dp" android:layout_margin="4dp" android:layout_columnSpan="2" android:background="@drawable/bg_input" android:backgroundTint="#E91E63" android:text="M1" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <View android:layout_width="20dp" android:layout_height="40dp" />
                    <TextView android:id="@+id/seatM2" android:layout_width="88dp" android:layout_height="40dp" android:layout_margin="4dp" android:layout_columnSpan="2" android:background="@drawable/bg_input" android:backgroundTint="#E91E63" android:text="M2" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                    <TextView android:id="@+id/seatM3" android:layout_width="88dp" android:layout_height="40dp" android:layout_margin="4dp" android:layout_columnSpan="2" android:background="@drawable/bg_input" android:backgroundTint="#E91E63" android:text="M3" android:textColor="@color/text_primary" android:textStyle="bold" android:gravity="center" android:textSize="11sp"/>
                </GridLayout>
            </HorizontalScrollView>

            <GridLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="40dp"
                android:columnCount="3"
                android:rowCount="2">

                <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_input"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Thường" android:textColor="@color/text_secondary_black" android:textSize="12sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_input" android:backgroundTint="#D4AF37"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIP" android:textColor="@color/text_secondary_black" android:textSize="12sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:gravity="center_vertical" android:layout_marginBottom="12dp">
                    <View android:layout_width="24dp" android:layout_height="16dp" android:background="@drawable/bg_input" android:backgroundTint="#E91E63"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ghế Đôi" android:textColor="@color/text_secondary_black" android:textSize="12sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <View android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_neon_button"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đang chọn" android:textColor="@color/text_secondary_black" android:textSize="12sp" android:layout_marginStart="8dp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="100dp" android:layout_height="wrap_content" android:gravity="center_vertical">
                    <View android:layout_width="16dp" android:layout_height="16dp" android:background="@drawable/bg_input" android:backgroundTint="#1F2833"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đã đặt" android:textColor="@color/text_secondary_black" android:textSize="12sp" android:layout_marginStart="8dp"/>
                </LinearLayout>
            </GridLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="#E60B0C10"
        android:paddingHorizontal="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">
            <TextView
                android:id="@+id/tvSelectedSeatsInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tổng cộng (0 ghế)"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />
            <TextView
                android:id="@+id/tvTotalPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="0 VNĐ"
                android:textColor="@color/neon_cyan"
                android:textSize="22sp"
                android:textStyle="bold" />
        </LinearLayout>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnCheckout"
            android:layout_width="140dp"
            android:layout_height="50dp"
            android:background="@drawable/bg_neon_button"
            android:text="Thanh Toán"
            android:textAllCaps="false"
            android:textColor="@color/bg_main"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>